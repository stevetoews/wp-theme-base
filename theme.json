{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "useRootPaddingAwareAlignments": true,
    "appearanceTools": false,
    "color": {
      "background": true,
      "text": true,
      "link": false,
      "button": false,
      "caption": false,
      "heading": false,
      "custom": false,
      "customGradient": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "duotone": false,
      "palette": []
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true,
      "units": ["px", "rem", "%", "vw", "vh"]
    },
    "typography": {
      "customFontSize": false,
      "defaultFontSizes": false,
      "fontStyle": false,
      "fontWeight": false,
      "letterSpacing": false,
      "lineHeight": false,
      "textDecoration": false,
      "textTransform": false,
      "fluid": false,
      "fontSizes": []
    },
    "border": {
      "color": false,
      "radius": false,
      "style": false,
      "width": false
    },
    "layout": {
      "contentSize": "740px",
      "wideSize": "1200px"
    }
  },
  "styles": {
    "spacing": {
      "blockGap": "1.5rem"
    }
  }
}
